# =============================================================================
# .env.local.example — copie para .env.local e preencha.
# =============================================================================
#
# MODO MOCK (offline, sem Supabase):
#   Deixe as 3 variáveis NEXT_PUBLIC_SUPABASE_* / SERVICE_ROLE vazias.
#   O app roda com lib/mock-data.ts (dados em memória). SEM realtime.
#
# MODO SUPABASE (banco real + REALTIME entre usuários):
#   Preencha as 3 chaves abaixo e deixe NEXT_PUBLIC_DEV_USE_MOCK_DATA=false.
# =============================================================================

# --- Supabase (Settings → API no dashboard do projeto) -----------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SEGREDO — nunca commitar, nunca expor no client. Só server-side.
SUPABASE_SERVICE_ROLE_KEY=

# --- Modo de dados -----------------------------------------------------------
# false = usa o Supabase real (necessário pra realtime). true/omitido = mock.
NEXT_PUBLIC_DEV_USE_MOCK_DATA=false
# true = pula o login (dev). Em produção, mude para false.
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# --- Senha única de acesso (gate do site inteiro) ----------------------------
# Setar uma senha LIGA o gate: quem não tem a senha cai em /acesso.
# Deixar VAZIO desliga o gate (acesso direto — use só em dev local).
# Útil pra publicar sem login por usuário, mas sem deixar os dados públicos.
SITE_PASSWORD=

# --- Webhooks Bitrix (dev/teste local) ---------------------------------------
WEBHOOK_SECRET=dev-secret-change-me
