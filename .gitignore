# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dados locais reais (PII) — NUNCA versionar. Carregados só no localhost.
/data-local/

# uploads do modo mock (arquivos de teste local) — NUNCA versionar.
/.dev-uploads/

# Scripts one-off: ignorar JSONs intermediarios (contem dados pessoais)
scripts/_*.json

# Backups do banco (CPF + saude = PII) — por padrao gravam em ~/Backups, fora do
# repo; isto e so uma rede de seguranca caso BACKUP_DIR aponte pra dentro do repo.
/backups/
